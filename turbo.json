{
    "$schema": "https://turbo.build/schema.json",
    "pipeline": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**"]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "lint": {},
        "test": {
            "dependsOn": ["build"],
            "inputs": [
                "src/**/*.tsx",
                "src/**/*.ts",
                "plugins/**/*.test.ts",
                "plugins/**/*.test.tsx",
                "test/**/*.ts",
                "test/**/*.tsx",
                "vite.config.ts"
            ]
        }
    }
}
